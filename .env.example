# ─────────── Приложение ───────────
APP_NAME="КҲФ CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Локали контента: tj (по умолчанию + fallback), ru, en.
# APP_LOCALE — язык панели Filament и системных сообщений (редакторы — рус.).
# Локаль API задаётся префиксом пути /{tg|ru|en}/, без префикса = tj
# (см. docs/API-CONTRACT.md; не зависит от APP_LOCALE).
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ─────────── Логи ───────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────── База данных (MySQL 8, utf8mb4) ───────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khf_cms
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─────────── Сессии (тайм-аут CMS, минуты) ───────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─────────── Очереди / кеш / вещание ───────────
# Тяжёлое (конверсии изображений, вебхуки, письма) — только через queue worker.
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# ─────────── Файлы и медиа ───────────
# FILESYSTEM_DISK — диск по умолчанию; MEDIA_DISK — диск медиатеки (spatie).
# public → раздаётся по APP_URL/storage (нужен `php artisan storage:link`).
FILESYSTEM_DISK=local
MEDIA_DISK=public

# ─────────── Интеграция с фронтом (Next.js ISR) ───────────
# FRONTEND_URL — база фронта для вебхука ревалидации.
# REVALIDATE_SECRET — общий секрет (= x-revalidate-secret на фронте).
# См. docs/API-CONTRACT.md §5. Секреты — только в .env (не в БД/коде).
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=

# Пользователь Sanctum для статического read-only токена фронта
# (генерация токена — команда khf:generate-api-token / панель «API-токен»).
API_TOKEN_USER_EMAIL=api@khf.local

# ─────────── Учётная запись администратора (сидер, ToR §4) ───────────
# Создаётся/обновляется командой `php artisan migrate:fresh --seed`.
# Оставьте ADMIN_PASSWORD пустым — сидер сгенерирует надёжный пароль и
# один раз выведет его в консоль. В проде задайте пароль явно.
ADMIN_NAME="Администратор"
ADMIN_EMAIL=admin@khf.tj
ADMIN_PASSWORD=

# ─────────── Почта (уведомления дежурному о заявках ЧС — M3) ───────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@khf.tj"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────── Redis (опционально) ───────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MEMCACHED_HOST=127.0.0.1

# ─────────── AWS / S3 (опционально) ───────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
